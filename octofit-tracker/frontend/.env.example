# OctoFit Tracker Frontend Environment Variables
# Copy this file to .env and update with your actual values

# Codespace name for the development environment
# Example: rebuild-certain-ladybug-qj9j4wgq
REACT_APP_CODESPACE_NAME=your-codespace-name

# Backend API will be accessed at:
# https://{REACT_APP_CODESPACE_NAME}-8000.app.github.dev/api/
